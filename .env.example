# REQUIRED - These must be set in Vercel Project Settings > Environment Variables

# App URL (update for production)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Supabase Configuration (get from your Supabase project dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Admin - Required for server-side operations (DO NOT prefix with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Storage
SUPABASE_STORAGE_BUCKET_LISTINGS=listing-images
SUPABASE_STORAGE_BUCKET_DOCUMENTS=listing-documents

# Redis / Rate Limiting (Upstash — https://upstash.com)
# REQUIRED for production - Rate limiting falls back to unreliable in-memory without Redis
# Without this, rate limits reset on cold start and fail-closed endpoints will block requests.
# 1. Create a free Redis database at upstash.com
# 2. Copy the REST URL and token from the database dashboard
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Cloudflare Turnstile (optional in local dev, recommended in production)
# If omitted in local development, bot-protected forms continue in fail-open DX mode.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# Sentry Error Tracking (FREE TIER: 5,000 errors/month)
# Setup: https://sentry.io (create Next.js project, get DSN)
# Public DSN - safe to expose in client code
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
# Server-side auth token (in Vercel env only, never prefix with NEXT_PUBLIC_)
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# Optional - Demo user password for seeding and E2E login
# SUPABASE_DEMO_USER_PASSWORD=test-123456

# Feature Flags (all optional, default false)
NEXT_PUBLIC_ENABLE_BILLING=false
NEXT_PUBLIC_ENABLE_AI=false
NEXT_PUBLIC_ENABLE_CHAT=false
NEXT_PUBLIC_ENABLE_COMPARE=true
NEXT_PUBLIC_ENABLE_DOCS=false
NEXT_PUBLIC_ENABLE_PWA=false


# Email (Resend) — https://resend.com
# 1. resend.com'dan ücretsiz hesap aç, API key al
# 2. Domain doğrulaması yapılana kadar onboarding@resend.dev kullanılabilir
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=OtoBurada <destek@otoburada.com>

# Internal API Secret — server-to-server çağrılar için (örn: /api/notifications/publish)
# Rastgele güçlü bir string gir: openssl rand -hex 32
INTERNAL_API_SECRET=your-internal-api-secret-here

# Payments (Iyzico) — REQUIRED for production payments
# CRITICAL: Both keys are validated at startup in production.
# Missing or placeholder values will prevent the app from starting.
#
# 1. Get credentials from Iyzico merchant panel (sandbox or production)
# 2. Set IYZICO_BASE_URL to https://sandbox-api.iyzipay.com for testing
# 3. Set IYZICO_BASE_URL to https://api.iyzipay.com for production
#
# ── SECURITY: Do NOT commit real credentials to version control ──
IYZICO_API_KEY=your-iyzico-api-key-here
IYZICO_SECRET_KEY=your-iyzico-secret-key-here
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Cron Security — Vercel Cron job'larını yetkisiz çağrılardan korur
# Rastgele güçlü bir string gir (örn: openssl rand -hex 32)
CRON_SECRET=your-cron-secret-here

# Database URL (pg_cron ve migration scriptleri için)
# NOT: Üretim ortamında Connection Pooling (PgBouncer/Supavisor) için 6543 portunu kullanın.
# Supabase Dashboard > Settings > Database > Connection String > Transaction mode
SUPABASE_DB_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:6543/postgres

# Rate Limiting Bypass IPs (OPTIONAL - Use with extreme caution)
# ── SECURITY WARNING: Issue LOGIC-04 - Rate Limit Bypass Documentation ─────────────
# Comma-separated list of IP addresses that bypass rate limiting.
# ONLY use for trusted infrastructure (monitoring, health checks, CI/CD).
# NEVER add user IPs or untrusted sources - creates DDoS vulnerability.
#
# Examples:
# - Monitoring service: 203.0.113.10
# - CI/CD pipeline: 198.51.100.20
# - Health check endpoint: 192.0.2.30
#
# Format: IP1,IP2,IP3 (no spaces)
# Leave empty or comment out if not needed
# RATE_LIMIT_BYPASS_IPS=203.0.113.10,198.51.100.20
