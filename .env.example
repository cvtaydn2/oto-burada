# REQUIRED - These must be set in Vercel Project Settings > Environment Variables

# App URL (update for production)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Supabase Configuration (get from your Supabase project dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Admin - Required for server-side operations (DO NOT prefix with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Storage
SUPABASE_STORAGE_BUCKET_LISTINGS=listing-images
SUPABASE_STORAGE_BUCKET_DOCUMENTS=listing-documents

# Redis / Rate Limiting (Upstash — https://upstash.com)
# REQUIRED for production - Rate limiting falls back to unreliable in-memory without Redis
# Without this, rate limits reset on cold start and fail-closed endpoints will block requests.
# 1. Create a free Redis database at upstash.com
# 2. Copy the REST URL and token from the database dashboard
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Optional - Demo user password for seeding (only if needed)
# SUPABASE_DEMO_USER_PASSWORD=your-password

# Error Monitoring & Analytics (PostHog) — https://posthog.com
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=your-posthog-project-api-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Email (Resend) — https://resend.com
# 1. resend.com'dan ücretsiz hesap aç, API key al
# 2. Domain doğrulaması yapılana kadar onboarding@resend.dev kullanılabilir
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=OtoBurada <destek@otoburada.com>

# Internal API Secret — server-to-server çağrılar için (örn: /api/notifications/publish)
# Rastgele güçlü bir string gir: openssl rand -hex 32
INTERNAL_API_SECRET=your-internal-api-secret-here

# Payments (Iyzico) — ödeme akışları bu anahtarlar olmadan pasif kalır
# CRITICAL: IYZICO_SECRET_KEY required for webhook signature verification
# Production: Use production keys from Iyzico merchant panel
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Cron Security — Vercel Cron job'larını yetkisiz çağrılardan korur
# Rastgele güçlü bir string gir (örn: openssl rand -hex 32)
CRON_SECRET=your-cron-secret-here

# Database URL (pg_cron ve migration scriptleri için)
# NOT: Üretim ortamında Connection Pooling (PgBouncer/Supavisor) için 6543 portunu kullanın.
# Supabase Dashboard > Settings > Database > Connection String > Transaction mode
SUPABASE_DB_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:6543/postgres
