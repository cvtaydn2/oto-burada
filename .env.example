# REQUIRED - These must be set in Vercel Project Settings > Environment Variables

# App URL (update for production)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Supabase Configuration (get from your Supabase project dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Admin - Required for server-side operations (DO NOT prefix with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Storage
SUPABASE_STORAGE_BUCKET_LISTINGS=listing-images

# Redis Configuration (Optional, for rate limiting and caching)
# Note: Use Upstash for Edge support, or standard Redis for Node.js runtime
REDIS_HOST=
REDIS_PORT=
REDIS_USER=
REDIS_PASSWORD=

# Optional - Demo user password for seeding (only if needed)
# SUPABASE_DEMO_USER_PASSWORD=your-password