# ============================================================================
# OtoBurada - Local Development Environment Template
# ============================================================================
# IMPORTANT: Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git (it's in .gitignore)
# ============================================================================

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_STORAGE_BUCKET_LISTINGS=listing-images

# Database URL (for migrations)
# Get from: Supabase Dashboard > Settings > Database > Connection String (Transaction mode, port 6543)
SUPABASE_DB_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# PostHog Analytics
# Get from: https://posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key-here
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=your-posthog-token-here

# Upstash Redis (Distributed Rate Limiting)
# Get from: https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here

# Email Service (Resend)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-key-here
RESEND_FROM_EMAIL=onboarding@resend.dev

# Internal API Secret (generate with: openssl rand -hex 32)
INTERNAL_API_SECRET=generate-a-random-32-char-secret-here

# Cron Secret (generate with: openssl rand -hex 32)
CRON_SECRET=generate-a-random-32-char-secret-here

# Iyzico Payment Gateway (Sandbox for development)
# Get from: https://sandbox-merchant.iyzipay.com/
IYZICO_API_KEY=sandbox-your-api-key-here
IYZICO_SECRET_KEY=sandbox-your-secret-key-here
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# E2E Test Credentials (optional - for Playwright tests)
E2E_TEST_EMAIL=test@example.com
E2E_TEST_PASSWORD=test-password-here

# Development Only - Rate Limit Bypass (REMOVE IN PRODUCTION)
# Only use for localhost development. Never use in production.
RATE_LIMIT_BYPASS_IPS="::1,127.0.0.1"
