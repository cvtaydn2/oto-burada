{
  "buildCommand": "npm run build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/main",
      "schedule": "0 0 * * *",
      "description": "Master daily cron: expire dopings, listings, reservations, cleanup payments, saved-search notifications"
    },
    {
      "path": "/api/cron/outbox",
      "schedule": "* * * * *",
      "description": "Outbox processor: email notifications, compliance, reconciliation (every minute)"
    },
    {
      "path": "/api/cron/process-fulfillment-jobs",
      "schedule": "* * * * *",
      "description": "Fulfillment job processor: payment retries, doping activation, credit adjustments (every minute)"
    },
    {
      "path": "/api/cron/sync-listing-views",
      "schedule": "*/5 * * * *",
      "description": "Sync listing view counts from cache to database (every 5 minutes)"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/icons/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    }
  ]
}
