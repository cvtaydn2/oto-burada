{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "noEmit": true,
        "types": [
            "vitest/globals"
        ]
    },
    "include": [
        "next-env.d.ts",
        "src/**/*.test.ts",
        "src/**/*.test.tsx",
        "src/**/__tests__/**/*.ts",
        "src/**/__tests__/**/*.tsx"
    ],
    "exclude": [
        "node_modules",
        "scratch",
        "lib/claude-code-templates"
    ]
}